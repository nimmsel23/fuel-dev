#!/usr/bin/env python3
"""
gemini-estimate — Standalone macro estimation via Gemini API

Usage:
  gemini-estimate "Wiener Schnitzel mit Kartoffeln"

Output: JSON with {kcal, protein, carbs, fat}
"""

from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path
import urllib.request
import urllib.error

# ── Load .env files ───────────────────────────────────────────────────────────

def _load_env_file(path: Path) -> None:
    if path.exists():
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    key, sep, value = line.partition("=")
                    if sep:
                        os.environ[key.strip()] = value.strip()

_load_env_file(Path.home() / ".env" / "gemini.env")

# ── Gemini API ─────────────────────────────────────────────────────────────────

GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY", "")
GEMINI_MODEL = os.environ.get("GEMINI_MODEL", "gemini-flash-latest")
GEMINI_API_URL = f"https://generativelanguage.googleapis.com/v1beta/models/{GEMINI_MODEL}:generateContent"

def estimate_macros(description: str) -> dict:
    """Estimate macros for a meal description via Gemini."""
    if not GEMINI_API_KEY:
        return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0, "_error": "GEMINI_API_KEY not set"}

    prompt = f"""Schätze die Nährwerte (pro Portion, durchschnittliche Menge) für: "{description}"

Antworte NUR mit JSON (keine weiteren Erklärungen):
{{"kcal": <Zahl>, "protein": <Zahl>, "carbs": <Zahl>, "fat": <Zahl>}}
"""

    try:
        payload = {"contents": [{"parts": [{"text": prompt}]}]}
        data = json.dumps(payload, ensure_ascii=False).encode('utf-8')
        req = urllib.request.Request(
            GEMINI_API_URL,
            data=data,
            headers={"Content-Type": "application/json", "X-goog-api-key": GEMINI_API_KEY},
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())

        if "candidates" in result and result["candidates"]:
            text = result["candidates"][0]["content"]["parts"][0]["text"].strip()
            try:
                macros = json.loads(text)
                return {
                    "kcal": int(macros.get("kcal", 0)),
                    "protein": round(macros.get("protein", 0) * 10) / 10,
                    "carbs": round(macros.get("carbs", 0) * 10) / 10,
                    "fat": round(macros.get("fat", 0) * 10) / 10,
                }
            except json.JSONDecodeError:
                json_match = re.search(r'\{[^{}]*\}', text, re.DOTALL)
                if json_match:
                    macros = json.loads(json_match.group())
                    return {
                        "kcal": int(macros.get("kcal", 0)),
                        "protein": round(macros.get("protein", 0) * 10) / 10,
                        "carbs": round(macros.get("carbs", 0) * 10) / 10,
                        "fat": round(macros.get("fat", 0) * 10) / 10,
                    }
                else:
                    return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0, "_error": "JSON parse failed"}
        return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0, "_error": "No response from Gemini"}
    except Exception as e:
        return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0, "_error": str(e)}

def main():
    if len(sys.argv) < 2:
        print(json.dumps({"error": "Usage: gemini-estimate 'meal description'"}), file=sys.stderr)
        sys.exit(1)

    description = sys.argv[1]
    result = estimate_macros(description)
    print(json.dumps(result, ensure_ascii=False))

if __name__ == "__main__":
    main()
