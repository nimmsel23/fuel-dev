{
  "name": "fuelctx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fuel Centre - nutrition tracking for coaches",
  "scripts": {
    "dev": "nodemon --watch server.mjs --watch src --watch index.html --watch vite.config.js --watch tailwind.config.cjs --watch postcss.config.cjs --ext js,jsx,mjs,cjs,html,css --signal SIGTERM --exec node scripts/dev-runner.mjs",
    "start": "node server.mjs",
    "ui:dev": "vite",
    "build": "vite build",
    "prod": "PORT=7000 HOST=0.0.0.0 FUEL_STATIC_DIR=/opt/fuel node server.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.59.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "recharts": "^2.13.1",
    "tailwind-merge": "^2.5.4",
    "vite-plugin-pwa": "^1.3.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
