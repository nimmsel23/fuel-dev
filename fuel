#!/usr/bin/env python3
"""
fuel — Nutrition & Supplement Tracker CLI

Meals:
  fuel meal log "Nussschnecke Billa" --kcal 250 --protein 5 --carbs 40 --fat 12
  fuel meal log "..." --kcal 250 --save-catalog     (speichert auch im Catalog)
  fuel meal today                                    (was heute gegessen)

Supplements:
  fuel melatonin            mit Default-Dosis aus catalog.json
  fuel melatonin 2          custom Dosis (gleiche Einheit wie catalog)
  fuel melatonin kollagen   mehrere Supplements auf einmal
  fuel melatonin --time night  Zeit-of-Day überschreiben

Überblick:
  fuel today                was heute geloggt wurde
  fuel list                 alle Supplements mit Default-Dosis
  fuel week                 Wochenübersicht mit CSV-Export
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from datetime import date, datetime, timedelta, timezone
from pathlib import Path
import urllib.request
import urllib.error

import typer
from loguru import logger
from pydantic import BaseModel, ConfigDict, Field, ValidationError
import pandas as pd
from rich.console import Console
from rich.table import Table

console = Console()

# ── API Base URL ───────────────────────────────────────────────────────────────

API_BASE = os.environ.get("FUEL_API_URL", "http://127.0.0.1:9000")

def _api_call(method: str, endpoint: str, body: dict | None = None) -> dict:
    """Macht HTTP-Call zu Fuel-API."""
    url = f"{API_BASE}{endpoint}"
    headers = {"Content-Type": "application/json"}

    try:
        if method == "GET":
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req) as resp:
                return json.loads(resp.read())
        elif method == "POST":
            data = json.dumps(body, ensure_ascii=False).encode('utf-8')
            req = urllib.request.Request(url, data=data, headers=headers, method="POST")
            with urllib.request.urlopen(req) as resp:
                return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        gum_log("error", f"API Error {e.code}: {e.reason}")
        raise SystemExit(1)
    except urllib.error.URLError as e:
        gum_log("error", f"API Fehler (Server antwortet nicht): {e.reason}")
        raise SystemExit(1)

# ── Validation (Pydantic) ──────────────────────────────────────────────────────

class SupplementInput(BaseModel):
    model_config = ConfigDict(validate_assignment=True)

    name: str = Field(..., min_length=1, description="Supplement name")
    dose: float | None = Field(None, ge=0, description="Dose amount")
    unit: str | None = Field(None, description="Unit (mg, g, etc.)")
    time_of_day: str | None = Field(None, description="morning, evening, night, any")
    notes: str = Field("", description="Optional notes")

class MealInput(BaseModel):
    model_config = ConfigDict(validate_assignment=True)

    description: str = Field(..., min_length=1, description="Meal description")
    kcal: float = Field(0, ge=0, description="Calories")
    protein: float = Field(0, ge=0, description="Protein grams")
    carbs: float = Field(0, ge=0, description="Carbs grams")
    fat: float = Field(0, ge=0, description="Fat grams")
    notes: str = Field("", description="Optional notes")

# ── Pfade ──────────────────────────────────────────────────────────────────────

FUEL_DIR    = Path(os.environ.get("AOS_FUEL_DIR", Path.home() / ".aos" / "fuel"))
CATALOG     = FUEL_DIR / "supplements" / "catalog.json"
LOGS_DIR    = FUEL_DIR / "supplements" / "logs"

# ── gum ───────────────────────────────────────────────────────────────────────

def _has_gum() -> bool:
    return bool(shutil.which("gum"))

def gum_log(level: str, msg: str) -> None:
    if _has_gum():
        subprocess.run(["gum", "log", f"--level={level}", msg])
    else:
        colors = {"info": "\033[1;32m", "warn": "\033[1;33m", "error": "\033[1;31m"}
        dest = sys.stderr if level == "error" else sys.stdout
        print(f"{colors.get(level, '')}{msg}\033[0m", file=dest)

def gum_header(title: str) -> None:
    if _has_gum():
        subprocess.run(["gum", "style", "--foreground=212", "--bold", title])
    else:
        print(f"\n\033[1;35m{title}\033[0m")

def gum_table(header: list[str], rows: list[list[str]], widths: list[int]) -> None:
    lines = [",".join(header)] + [",".join(r) for r in rows]
    if _has_gum():
        subprocess.run(
            ["gum", "table", "--print", "--separator=,", f"--widths={','.join(map(str, widths))}"],
            input="\n".join(lines), text=True,
        )
    else:
        fmt = "  " + "  ".join(f"{{:<{w}}}" for w in widths)
        for line in lines:
            print(fmt.format(*line.split(",", len(widths) - 1)))

# ── Catalog ────────────────────────────────────────────────────────────────────

def load_catalog() -> dict[str, dict]:
    """Gibt {id: supplement_dict} zurück."""
    if not CATALOG.exists():
        gum_log("error", f"catalog.json nicht gefunden: {CATALOG}")
        raise SystemExit(1)
    data = json.loads(CATALOG.read_text())
    return {item["id"]: item for item in data.get("items", [])}

# ── Log I/O ────────────────────────────────────────────────────────────────────

def log_path(day: str) -> Path:
    return LOGS_DIR / f"{day}.json"

def read_log(day: str) -> dict:
    p = log_path(day)
    if p.exists():
        return json.loads(p.read_text())
    return {"date": day, "intakes": []}

def write_log(day: str, data: dict) -> None:
    LOGS_DIR.mkdir(parents=True, exist_ok=True)
    log_path(day).write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")

# ── Kern-Logik ─────────────────────────────────────────────────────────────────

def _make_id() -> str:
    import hashlib, time
    return "supp_" + hashlib.sha1(str(time.time()).encode()).hexdigest()[:12]

def do_log(supplement_id: str, dose: float | None, time_of_day: str | None, day: str | None) -> None:
    catalog = load_catalog()
    if supplement_id not in catalog:
        gum_log("error", f"Unbekannt: {supplement_id}  (gültig: {', '.join(catalog)})")
        raise SystemExit(1)

    supp   = catalog[supplement_id]
    today  = day or date.today().isoformat()
    dose   = dose if dose is not None else supp["default_dose"]
    tod    = time_of_day or supp.get("default_time_of_day", "any")
    unit   = supp["unit"]

    # Validate input
    try:
        SupplementInput(
            name=supp["name"],
            dose=dose,
            unit=unit,
            time_of_day=tod,
        )
    except ValidationError as e:
        gum_log("error", f"Validation error: {e.error_count()} Fehler")
        for err in e.errors():
            gum_log("error", f"  {err['loc'][0]}: {err['msg']}")
        raise SystemExit(1)

    data   = read_log(today)
    entry  = {
        "id":             _make_id(),
        "supplement_id":  supplement_id,
        "name":           supp["name"],
        "dose":           dose,
        "unit":           unit,
        "time_of_day":    tod,
        "notes":          "",
        "time":           datetime.now(timezone.utc).isoformat(),
    }
    data["intakes"].append(entry)
    write_log(today, data)

    total_today = len(data["intakes"])
    day_label = "heute"
    if today != date.today().isoformat():
        yesterday = (date.today() - timedelta(days=1)).isoformat()
        if today == yesterday:
            day_label = "gestern"
        else:
            day_label = f"am {today}"

    gum_log("info", f"{supp['name']} {dose}{unit} ({tod}) geloggt — {day_label} gesamt: {total_today} Intake(s)")

def do_today(day: str | None) -> None:
    today = day or date.today().isoformat()
    data  = read_log(today)
    intakes = data.get("intakes", [])

    if not intakes:
        console.print(f"[yellow]Noch nichts geloggt am {today}[/yellow]")
        return

    table = Table(title=f"Fuel Supplements — {today}", show_header=True, header_style="bold magenta")
    table.add_column("SUPPLEMENT", style="green")
    table.add_column("DOSIS", style="cyan")
    table.add_column("ZEIT", style="blue")

    for i in intakes:
        table.add_row(
            i["name"],
            f"{i['dose']}{i['unit']}",
            i["time_of_day"]
        )

    console.print(table)

# ── Meal Logging (Nutrition) ───────────────────────────────────────────────────

def do_meal_log(description: str, kcal: float, protein: float, carbs: float, fat: float, notes: str, day: str | None, save_catalog: bool) -> None:
    """Loggt eine Mahlzeit über API und speichert optional im Catalog."""
    today = day or date.today().isoformat()

    # Validate input
    try:
        MealInput(
            description=description,
            kcal=kcal,
            protein=protein,
            carbs=carbs,
            fat=fat,
            notes=notes,
        )
    except ValidationError as e:
        gum_log("error", f"Validation error: {e.error_count()} Fehler")
        for err in e.errors():
            gum_log("error", f"  {err['loc'][0]}: {err['msg']}")
        raise SystemExit(1)

    # Log meal via API
    payload = {
        "date": today,
        "meal": {
            "meal_type": "lunch",
            "description": description,
            "kcal": kcal,
            "protein": protein,
            "carbs": carbs,
            "fat": fat,
            "notes": notes,
        }
    }

    try:
        result = _api_call("POST", "/nutrition/log", payload)
        gum_log("info", f"{description} ({kcal} kcal) geloggt — {today}")
    except SystemExit:
        raise

    # Save to catalog if requested
    if save_catalog:
        catalog_item = {
            "item": {
                "name": description,
                "kcal": kcal,
                "protein": protein,
                "carbs": carbs,
                "fat": fat,
            }
        }
        try:
            _api_call("POST", "/nutrition/catalog", catalog_item)
            gum_log("info", f"Zum Catalog hinzugefügt: {description}")
        except SystemExit:
            pass  # Log successful, catalog save failed is non-critical

# ── Typer App ──────────────────────────────────────────────────────────────────

app = typer.Typer(
    name="fuel",
    help=__doc__,
    add_completion=True,
    invoke_without_command=True,
)

def _preprocess_args() -> None:
    """Convert --1d, --2d, --yesterday to --day YYYY-MM-DD before Typer sees it."""
    i = 0
    while i < len(sys.argv):
        arg = sys.argv[i]

        # --yesterday → --day <yesterday>
        if arg == "--yesterday":
            yesterday = (date.today() - timedelta(days=1)).isoformat()
            sys.argv[i] = "--day"
            sys.argv.insert(i + 1, yesterday)
            i += 2

        # --1d, --2d, etc. → --day <date>
        elif arg.startswith("--") and arg[2:].endswith("d"):
            try:
                days = int(arg[2:-1])
                target_date = (date.today() - timedelta(days=days)).isoformat()
                sys.argv[i] = "--day"
                sys.argv.insert(i + 1, target_date)
                i += 2
            except ValueError:
                i += 1
        else:
            i += 1

def _print_help_with_catalog() -> None:
    """Print extended help mit Supplement-Catalog."""
    catalog = load_catalog()
    console.print(__doc__)
    console.print("\n[bold magenta]Available Supplements:[/bold magenta]")

    table = Table(show_header=True, header_style="bold cyan")
    table.add_column("ID", style="green")
    table.add_column("NAME", style="cyan")
    table.add_column("DEFAULT", style="yellow")
    table.add_column("TIME", style="blue")

    for sid, s in catalog.items():
        table.add_row(
            sid,
            s["name"],
            f"{s['default_dose']}{s['unit']}",
            s.get("default_time_of_day", "any")
        )

    console.print(table)
    console.print("\n[dim]Commands: log, today, list, week[/dim]")

@app.callback(invoke_without_command=True)
def main(ctx: typer.Context) -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        _print_help_with_catalog()
        raise SystemExit(0)

    if ctx.invoked_subcommand is None and len(sys.argv) > 1:
        first_arg = sys.argv[1]
        catalog = load_catalog()
        # Wenn erstes Argument ist Supplement → log command
        if first_arg in catalog:
            ctx.invoke(log_command)

@app.command(name="log", help="Supplement(e) loggen")
def log_command(
    supplements: list[str]   = typer.Argument(..., help="Supplement-IDs (z.B. melatonin kollagen)"),
    dose:       float | None = typer.Argument(None, help="Dosis für erstes Supplement (Standard: catalog)"),
    time:       str | None   = typer.Option(None, "--time", "-t", help="morning/evening/night/any"),
    day:        str | None   = typer.Option(None, "--day", "-d", help="Datum YYYY-MM-DD (Standard: heute)"),
) -> None:
    for i, supp in enumerate(supplements):
        d = dose if i == 0 else None
        do_log(supp, d, time, day)

@app.command(name="meal-log", help="Mahlzeit loggen und optional im Catalog speichern")
def meal_log_command(
    description: str          = typer.Argument(..., help="Mahlzeitbeschreibung (z.B. 'Nussschnecke Billa')"),
    kcal:       float | None  = typer.Option(0, "--kcal", help="Kalorien"),
    protein:    float | None  = typer.Option(0, "--protein", help="Protein in Gramm"),
    carbs:      float | None  = typer.Option(0, "--carbs", help="Kohlenhydrate in Gramm"),
    fat:        float | None  = typer.Option(0, "--fat", help="Fett in Gramm"),
    notes:      str | None    = typer.Option("", "--notes", "-n", help="Notizen"),
    day:        str | None    = typer.Option(None, "--day", "-d", help="Datum YYYY-MM-DD (Standard: heute)"),
    save_catalog: bool        = typer.Option(False, "--save-catalog", "-s", help="Im Catalog speichern"),
) -> None:
    do_meal_log(description, kcal or 0, protein or 0, carbs or 0, fat or 0, notes or "", day, save_catalog)

@app.command(help="Was heute geloggt wurde")
def today(
    day: str | None = typer.Option(None, "--day", "-d", help="Datum YYYY-MM-DD"),
