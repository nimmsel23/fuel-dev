#!/usr/bin/env python3
"""
fuel-meal — Meal logging via fuel CLI (interactive, manual, Gemini-powered)

Usage:
  fuel meal                              # Interactive fzf catalog browser
  fuel meal "Nussschnecke" --kcal 250    # With manual macros
  fuel meal "Wiener Schnitzel"           # Auto-estimate via Gemini
  fuel meal "Name" --save-catalog        # Save to reusable catalog
"""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from datetime import date, datetime, timezone
from pathlib import Path
import urllib.request
import urllib.error

from loguru import logger
from pydantic import BaseModel, ConfigDict, Field, ValidationError
from rich.console import Console

console = Console()

# ── Load .env files ────────────────────────────────────────────────────────────

def _load_env_file(path: Path) -> None:
    if path.exists():
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    key, sep, value = line.partition("=")
                    if sep:
                        os.environ[key.strip()] = value.strip()

_load_env_file(Path.home() / ".env" / "gemini.env")

# ── API URLs ───────────────────────────────────────────────────────────────────

API_BASE = os.environ.get("FUEL_API_URL", "http://127.0.0.1:9000")
GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY", "")
GEMINI_MODEL = os.environ.get("GEMINI_MODEL", "gemini-flash-latest")
GEMINI_API_URL = f"https://generativelanguage.googleapis.com/v1beta/models/{GEMINI_MODEL}:generateContent"

# ── gum logging ────────────────────────────────────────────────────────────────

def _has_gum() -> bool:
    return bool(shutil.which("gum"))

def gum_log(level: str, msg: str) -> None:
    if _has_gum():
        subprocess.run(["gum", "log", f"--level={level}", msg])
    else:
        colors = {"info": "\033[1;32m", "warn": "\033[1;33m", "error": "\033[1;31m"}
        dest = sys.stderr if level == "error" else sys.stdout
        print(f"{colors.get(level, '')}{msg}\033[0m", file=dest)

# ── Validation ─────────────────────────────────────────────────────────────────

class MealInput(BaseModel):
    model_config = ConfigDict(validate_assignment=True)
    description: str = Field(..., min_length=1)
    kcal: float = Field(0, ge=0)
    protein: float = Field(0, ge=0)
    carbs: float = Field(0, ge=0)
    fat: float = Field(0, ge=0)
    notes: str = Field("")

# ── API ────────────────────────────────────────────────────────────────────────

def _api_call(method: str, endpoint: str, body: dict | None = None) -> dict:
    url = f"{API_BASE}{endpoint}"
    headers = {"Content-Type": "application/json"}
    try:
        if method == "GET":
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req) as resp:
                return json.loads(resp.read())
        elif method == "POST":
            data = json.dumps(body, ensure_ascii=False).encode('utf-8')
            req = urllib.request.Request(url, data=data, headers=headers, method="POST")
            with urllib.request.urlopen(req) as resp:
                return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        gum_log("error", f"API Error {e.code}: {e.reason}")
        raise SystemExit(1)
    except urllib.error.URLError as e:
        gum_log("error", f"API Fehler: {e.reason}")
        raise SystemExit(1)

def _parse_macros_with_gemini(description: str) -> dict:
    """Auto-estimate macros via Gemini."""
    if not GEMINI_API_KEY:
        gum_log("warn", "GEMINI_API_KEY nicht gesetzt")
        return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0}

    prompt = f"""Schätze die Nährwerte (pro Portion) für: "{description}"

Antworte NUR mit JSON:
{{"kcal": <Zahl>, "protein": <Zahl>, "carbs": <Zahl>, "fat": <Zahl>}}
"""

    try:
        payload = {"contents": [{"parts": [{"text": prompt}]}]}
        data = json.dumps(payload, ensure_ascii=False).encode('utf-8')
        req = urllib.request.Request(
            GEMINI_API_URL,
            data=data,
            headers={"Content-Type": "application/json", "X-goog-api-key": GEMINI_API_KEY},
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())

        if "candidates" in result and result["candidates"]:
            text = result["candidates"][0]["content"]["parts"][0]["text"].strip()
            try:
                macros = json.loads(text)
            except json.JSONDecodeError:
                json_match = re.search(r'\{[^{}]*\}', text, re.DOTALL)
                if json_match:
                    macros = json.loads(json_match.group())
                else:
                    return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0}
            gum_log("info", f"Gemini: {macros.get('kcal', 0)} kcal")
            return macros
    except Exception as e:
        gum_log("warn", f"Gemini Fehler: {e}")
    return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0}

# ── Interactive Mode ───────────────────────────────────────────────────────────

def do_meal_interactive() -> None:
    """Interactive fzf catalog browser."""
    try:
        result = _api_call("GET", "/nutrition/catalog")
        items = result.get("items", [])
    except SystemExit:
        gum_log("error", "Catalog nicht erreichbar")
        raise SystemExit(1)

    if not items:
        gum_log("warn", "Catalog ist leer")
        raise SystemExit(1)

    fzf_items = []
    for item in items:
        kcal = item.get("kcal", 0)
        label = f"{item['name']:<40} {kcal:>4} kcal"
        fzf_items.append((label, item))

    fzf_input = "\n".join([label for label, _ in fzf_items])

    try:
        result = subprocess.run(
            ["fzf", "--preview", "echo {}", "--height=15"],
            input=fzf_input,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode != 0:
            raise SystemExit(0)

        selected_label = result.stdout.strip()
        selected_item = None
        for label, item in fzf_items:
            if label == selected_label:
                selected_item = item
                break

        if not selected_item:
            gum_log("error", "Item nicht gefunden")
            raise SystemExit(1)

        do_meal_log(selected_item["name"], selected_item.get("kcal", 0),
                    selected_item.get("protein", 0), selected_item.get("carbs", 0),
                    selected_item.get("fat", 0), "", None, False)

    except FileNotFoundError:
        gum_log("error", "fzf nicht gefunden")
        raise SystemExit(1)

# ── Meal Logging ───────────────────────────────────────────────────────────────

def do_meal_log(description: str, kcal: float, protein: float, carbs: float, fat: float, notes: str, day: str | None, save_catalog: bool) -> None:
    today = day or date.today().isoformat()

    if kcal == 0 and protein == 0 and carbs == 0 and fat == 0:
        gum_log("info", f"Gemini schätzt Makros für '{description}'...")
        macros = _parse_macros_with_gemini(description)
        kcal, protein, carbs, fat = macros.get("kcal", 0), macros.get("protein", 0), macros.get("carbs", 0), macros.get("fat", 0)

    try:
        MealInput(description=description, kcal=kcal, protein=protein, carbs=carbs, fat=fat, notes=notes)
    except ValidationError as e:
        gum_log("error", f"Validation error: {e.error_count()} Fehler")
        raise SystemExit(1)

    payload = {
        "date": today,
        "meal": {
            "meal_type": "lunch",
            "description": description,
            "kcal": kcal,
            "protein": protein,
            "carbs": carbs,
            "fat": fat,
            "notes": notes,
        }
    }

    _api_call("POST", "/nutrition/log", payload)
    gum_log("info", f"{description} ({kcal} kcal) geloggt — {today}")

    if save_catalog:
        catalog_item = {
            "item": {
                "name": description,
                "kcal": kcal,
                "protein": protein,
                "carbs": carbs,
                "fat": fat,
            }
        }
        try:
            _api_call("POST", "/nutrition/catalog", catalog_item)
            gum_log("info", f"Zum Catalog hinzugefügt: {description}")
        except SystemExit:
            pass

# ── CLI ────────────────────────────────────────────────────────────────────────

def main():
    logger.remove()

    if len(sys.argv) == 1:
        do_meal_interactive()
        return

    description = None
    kcal = 0
    protein = 0
    carbs = 0
    fat = 0
    notes = ""
    day = None
    save_catalog = False

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] in ("--kcal",):
            kcal = float(args[i + 1]) if i + 1 < len(args) else 0
            i += 2
        elif args[i] in ("--protein",):
            protein = float(args[i + 1]) if i + 1 < len(args) else 0
            i += 2
        elif args[i] in ("--carbs",):
            carbs = float(args[i + 1]) if i + 1 < len(args) else 0
            i += 2
        elif args[i] in ("--fat",):
            fat = float(args[i + 1]) if i + 1 < len(args) else 0
            i += 2
        elif args[i] in ("--notes", "-n"):
            notes = args[i + 1] if i + 1 < len(args) else ""
            i += 2
        elif args[i] in ("--day", "-d"):
            day = args[i + 1] if i + 1 < len(args) else None
            i += 2
        elif args[i] in ("--save-catalog", "-s"):
            save_catalog = True
            i += 1
        elif not args[i].startswith("--") and not description:
            description = args[i]
            i += 1
        else:
            i += 1

    if description:
        do_meal_log(description, kcal, protein, carbs, fat, notes, day, save_catalog)
    else:
        gum_log("error", "Keine Mahlzeitbeschreibung gegeben")
        raise SystemExit(1)

if __name__ == "__main__":
    main()
