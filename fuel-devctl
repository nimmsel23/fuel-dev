#!/usr/bin/env bash
set -euo pipefail

PORT="${PORT:-9000}"
VITE_PORT="${VITE_PORT:-5173}"
HEALTH_URL="http://127.0.0.1:${PORT}/health"
V2_URL="http://127.0.0.1:${PORT}/v2"
DEV_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
LOGFILE="${LOGFILE:-/tmp/fuelctx-dev.log}"
PIDFILE="${PIDFILE:-/tmp/fuelctx-dev.pid}"

have_gum() { command -v gum >/dev/null 2>&1; }
msg()  { have_gum && gum log --level info  "$*" || printf '\033[1;32m%s\033[0m\n' "$*"; }
warn() { have_gum && gum log --level warn  "$*" >&2 || printf '\033[1;33m%s\033[0m\n' "$*" >&2; }
err()  { have_gum && gum log --level error "$*" >&2 || printf '\033[1;31m%s\033[0m\n' "$*" >&2; }
die()  { err "$*"; exit 1; }

cmd_status() {
  if curl -fsS --connect-timeout 1 --max-time 2 "$HEALTH_URL" >/dev/null 2>&1; then
    local pid="unknown"
    if [[ -f "$PIDFILE" ]]; then
      pid="$(cat "$PIDFILE" 2>/dev/null || true)"
    fi
    msg "fuel-dev is running on :$PORT (pid: ${pid:-unknown})"
    printf 'health: %s\n' "$HEALTH_URL"
    printf 'v2:     %s\n' "$V2_URL"
  else
    warn "fuel-dev is not responding on :$PORT"
    return 1
  fi
}

cmd_start() {
  if curl -fsS --connect-timeout 1 --max-time 2 "$HEALTH_URL" >/dev/null 2>&1; then
    warn "fuel-dev already running on :$PORT"
    return 0
  fi

  cd "$DEV_DIR"
  : > "$LOGFILE"
  PORT="$PORT" FUEL_VITE_ORIGIN="http://127.0.0.1:${VITE_PORT}" npm run dev >"$LOGFILE" 2>&1 &
  echo $! > "$PIDFILE"
  sleep 2

  if curl -fsS --connect-timeout 1 --max-time 3 "$HEALTH_URL" >/dev/null 2>&1; then
    msg "started fuel-dev"
    printf 'health: %s\n' "$HEALTH_URL"
    printf 'v2:     %s\n' "$V2_URL"
  else
    warn "fuel-dev did not come up cleanly; last log lines:"
    tail -30 "$LOGFILE" || true
    return 1
  fi
}

cmd_stop() {
  local pid=""
  if [[ -f "$PIDFILE" ]]; then
    pid="$(cat "$PIDFILE" 2>/dev/null || true)"
  fi

  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    sleep 1
    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  fi

  pkill -f "node.*scripts/dev-runner.mjs|nodemon.*scripts/dev-runner.mjs|node.*server.mjs|node_modules/.bin/vite|vite" >/dev/null 2>&1 || true
  rm -f "$PIDFILE"
  msg "stopped fuel-dev"
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_logs() {
  if [[ -f "$LOGFILE" ]]; then
    tail -f "$LOGFILE"
  else
    die "log file not found: $LOGFILE"
  fi
}

cmd_health() {
  local out
  if out="$(curl -fsS --connect-timeout 3 --max-time 8 "$HEALTH_URL" 2>&1)"; then
    msg "health OK  $HEALTH_URL"
    echo "$out"
  else
    warn "health FAIL  $HEALTH_URL"
    exit 1
  fi
}

cmd_build() {
  msg "==> npm run build"
  cd "$DEV_DIR"
  npm run build
}

cmd_dev() {
  msg "Starting fuel-dev in foreground..."
  msg "API:  :$PORT"
  msg "Vite: :$VITE_PORT"
  cd "$DEV_DIR"
  PORT="$PORT" FUEL_VITE_ORIGIN="http://127.0.0.1:${VITE_PORT}" npm run dev
}

cmd_gitstatus() {
  if [[ ! -d "$DEV_DIR/.git" ]]; then
    die "no .git in $DEV_DIR"
  fi
  msg "==> fuel-dev git status"
  git -C "$DEV_DIR" status --short --branch
}

cmd_help() {
  cat <<EOF
fuel-devctl — DEV control for fuel-dev (local Node API + Vite)

Commands:
  status      check whether fuel-dev responds on :$PORT
  start       start npm run dev in background
  stop        stop background fuel-dev processes
  restart     restart background fuel-dev processes
  logs        tail $LOGFILE
  health      GET $HEALTH_URL
  build       npm run build
  dev         run npm run dev in foreground
  gitstatus   git status of fuel-dev repo
  help        this message

Repo:    $DEV_DIR
Health:  $HEALTH_URL
v2:      $V2_URL
Log:     $LOGFILE
PID:     $PIDFILE
EOF
}

case "${1:-help}" in
  status)         cmd_status ;;
  start)          cmd_start ;;
  stop)           cmd_stop ;;
  restart)        cmd_restart ;;
  logs)           cmd_logs ;;
  health)         cmd_health ;;
  build)          cmd_build ;;
  dev)            cmd_dev ;;
  gitstatus)      cmd_gitstatus ;;
  help|--help|-h) cmd_help ;;
  *) die "unknown command: $1 (try: fuel-devctl help)" ;;
esac
