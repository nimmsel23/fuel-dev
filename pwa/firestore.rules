rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Nutrition & Supplements (Fuel Centre)
    match /nutrition/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /supplements/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Relax & Physio (Knowledge Base & Sessions)
    match /relax/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /physio/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Global Knowledge (optional, readable by all authenticated users)
    match /knowledge/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only via Admin SDK / CLI
    }
    
    // Knowledge Tasks (Trigger for local enrichment)
    match /knowledge_tasks/{taskId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false; // Only via Admin SDK / CLI
    }
  }
}
