#!/usr/bin/env python3
"""
gemini-compose — Compose meals from wger ingredients using Gemini

Usage:
  gemini-compose "Wiener Schnitzel mit Kartoffeln und Salat"

Output: JSON with {kcal, protein, carbs, fat, components: [{name, quantity_g, ...}]}
"""

from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path
import urllib.request
import urllib.error

# ── Load .env files ───────────────────────────────────────────────────────────

def _load_env_file(path: Path) -> None:
    if path.exists():
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    key, sep, value = line.partition("=")
                    if sep:
                        os.environ[key.strip()] = value.strip()

_load_env_file(Path.home() / ".env" / "gemini.env")

# ── Config ─────────────────────────────────────────────────────────────────────

GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY", "")
GEMINI_MODEL = os.environ.get("GEMINI_MODEL", "gemini-flash-latest")
GEMINI_API_URL = f"https://generativelanguage.googleapis.com/v1beta/models/{GEMINI_MODEL}:generateContent"
WGER_API_URL = "http://127.0.0.1:8000/api/v2"
WGER_API_TOKEN = os.environ.get("WGER_API_TOKEN", "92d9ea44fc0ac065e336e9ec443a196c40c68afe")

# ── Gemini: Parse meal into components ──────────────────────────────────────────

def parse_meal_with_gemini(description: str) -> list[dict]:
    """
    Ask Gemini to break down a meal into ingredients with quantities.
    Returns: [{"name": "Schnitzel", "quantity_g": 150}, ...]
    """
    if not GEMINI_API_KEY:
        return []

    prompt = f"""Zerlege diese Mahlzeit in ihre Zutaten mit Mengen:
"{description}"

Antworte NUR mit JSON (keine Erklärungen):
[{{"name": "<Zutat>", "quantity_g": <Menge>}}, ...]

Beispiel für "Wiener Schnitzel mit Kartoffeln":
[{{"name": "Schnitzel", "quantity_g": 150}}, {{"name": "Kartoffeln", "quantity_g": 200}}, {{"name": "Öl zum Braten", "quantity_g": 20}}]
"""

    try:
        payload = {"contents": [{"parts": [{"text": prompt}]}]}
        data = json.dumps(payload, ensure_ascii=False).encode('utf-8')
        req = urllib.request.Request(
            GEMINI_API_URL,
            data=data,
            headers={"Content-Type": "application/json", "X-goog-api-key": GEMINI_API_KEY},
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())

        if "candidates" in result and result["candidates"]:
            text = result["candidates"][0]["content"]["parts"][0]["text"].strip()
            try:
                components = json.loads(text)
                return components if isinstance(components, list) else []
            except json.JSONDecodeError:
                json_match = re.search(r'\[[^\[\]]*\]', text, re.DOTALL)
                if json_match:
                    try:
                        components = json.loads(json_match.group())
                        return components if isinstance(components, list) else []
                    except:
                        return []
    except Exception:
        pass

    return []

# ── wger: Search ingredients ───────────────────────────────────────────────────

def search_wger(ingredient_name: str, limit: int = 1) -> dict | None:
    """Search wger local database for ingredient. Returns best match."""
    try:
        url = f"{WGER_API_URL}/ingredient/?format=json&limit={limit}&name__search={urllib.parse.quote(ingredient_name)}"
        req = urllib.request.Request(
            url,
            headers={"Authorization": f"Token {WGER_API_TOKEN}"}
        )
        with urllib.request.urlopen(req, timeout=3) as resp:
            result = json.loads(resp.read())

        if result.get("results"):
            ing = result["results"][0]
            return {
                "wger_id": ing.get("id"),
                "name": ing.get("name", "").strip(),
                "brand": ing.get("brand", ""),
                "energy_kcal": round((ing.get("energy") or 0) * 10) / 10,
                "protein": round((float(ing.get("protein") or 0)) * 10) / 10,
                "carbs": round((float(ing.get("carbohydrates") or 0)) * 10) / 10,
                "fat": round((float(ing.get("fat") or 0)) * 10) / 10,
            }
    except Exception:
        pass

    return None

# ── Compose: Build full meal ───────────────────────────────────────────────────

def compose_meal(description: str) -> dict:
    """
    1. Parse meal with Gemini (gets components + quantities)
    2. Search each component in wger
    3. Calculate macros
    4. Return composed meal
    """
    components_input = parse_meal_with_gemini(description)
    if not components_input:
        return {"kcal": 0, "protein": 0, "carbs": 0, "fat": 0, "components": [], "_error": "Could not parse meal"}

    total_kcal = 0
    total_protein = 0
    total_carbs = 0
    total_fat = 0
    components = []

    for comp in components_input:
        ing_name = comp.get("name", "")
        quantity_g = comp.get("quantity_g", 100)

        if not ing_name:
            continue

        # Search in wger
        wger_ing = search_wger(ing_name, limit=1)
        if not wger_ing:
            continue

        # Scale by quantity (wger data per 100g)
        multiplier = quantity_g / 100
        kcal = round(wger_ing["energy_kcal"] * multiplier * 10) / 10
        protein = round(wger_ing["protein"] * multiplier * 10) / 10
        carbs = round(wger_ing["carbs"] * multiplier * 10) / 10
        fat = round(wger_ing["fat"] * multiplier * 10) / 10

        total_kcal += kcal
        total_protein += protein
        total_carbs += carbs
        total_fat += fat

        components.append({
            "wger_id": wger_ing["wger_id"],
            "name": wger_ing["name"],
            "quantity_g": quantity_g,
            "kcal": kcal,
            "protein": protein,
            "carbs": carbs,
            "fat": fat,
            "brand": wger_ing["brand"],
        })

    return {
        "kcal": int(round(total_kcal)),
        "protein": round(total_protein * 10) / 10,
        "carbs": round(total_carbs * 10) / 10,
        "fat": round(total_fat * 10) / 10,
        "components": components,
    }

def main():
    if len(sys.argv) < 2:
        print(json.dumps({"error": "Usage: gemini-compose 'meal description'"}), file=sys.stderr)
        sys.exit(1)

    description = sys.argv[1]
    result = compose_meal(description)
    print(json.dumps(result, ensure_ascii=False))

if __name__ == "__main__":
    main()
